<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/splash_bg">

    <!-- Floating circles (optional, replicating Compose) -->
    <!-- Not strictly necessary but we can add simple View circles if needed. Let's keep it simple first -->

    <ImageView
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_centerInParent="true"
        android:src="@drawable/ic_splash_logo"
        android:tint="@color/splash_text_primary" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="48dp"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FROM"
            android:textColor="@color/splash_text_secondary"
            android:textSize="12sp"
            android:letterSpacing="0.15"
            android:textAllCaps="true"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ELVAN"
            android:textColor="@color/splash_text_secondary"
            android:textSize="24sp"
            android:textStyle="bold"
            android:letterSpacing="0.3" />
    </LinearLayout>
</RelativeLayout>
