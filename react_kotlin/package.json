{
  "name": "elvan-niril",
  "version": "2.0.0",
  "description": "Free, open-source GST invoice & billing software for India. Tax Invoice, Proforma, Credit Note, Bill of Supply, Delivery Challan, GSTR-1 / GSTR-3B JSON exports, GSTR-2B reconciliation, e-Way Bill, TDS / TCS reports (Form 26Q / 27EQ), multi-currency for 22 countries, per-line custom units, rich-text Terms with 13 India presets, granular backup with optional Google Drive sync. Offline-first PWA. By elvan parthasarathy.",
  "author": "elvan parthasarathy <Contact@elvan parthasarathy.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ElvanParthasarathy/Niril.git"
  },
  "keywords": [
    "gst",
    "gst-invoice",
    "gst-billing-software",
    "free-billing-software",
    "invoice-generator",
    "tax-invoice",
    "billing-software-india",
    "gst-return",
    "gstr-1",
    "gstr-3b",
    "gstr-2b",
    "gstr-2b-reconciliation",
    "gstr-1-json-export",
    "gstr-3b-json-export",
    "tds",
    "tcs",
    "form-26q",
    "form-27eq",
    "section-194q",
    "section-206c",
    "e-way-bill",
    "delivery-challan",
    "credit-note",
    "proforma-invoice",
    "bill-of-supply",
    "pdf-generator",
    "offline-billing",
    "open-source",
    "vyapar-alternative",
    "tally-alternative",
    "zoho-alternative",
    "cleartax-alternative",
    "marg-erp-alternative",
    "mybillbook-alternative",
    "hsn-code",
    "sac-code",
    "uqc",
    "cgst-sgst-igst",
    "place-of-supply",
    "sez-invoice",
    "lut-export-invoice",
    "multi-currency-invoice",
    "international-invoice-india",
    "vat-invoice",
    "upi-qr-invoice",
    "pwa",
    "offline-pwa",
    "freelancer-invoice",
    "small-business-billing",
    "multi-business-profile",
    "multi-gstin",
    "rich-text-terms",
    "india-business-templates",
    "custom-units-invoice",
    "granular-backup",
    "google-drive-backup",
    "searchable-user-guide-pdf",
    "dark-mode-billing",
    "react",
    "vite",
    "expressjs",
    "india",
    "elvan parthasarathy"
  ],
  "type": "module",
  "main": "electron/main.cjs",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:win": "vite",
    "build": "vite build",
    "start": "vite build && vite preview",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:start": "electron electron/main.cjs",
    "electron:dev": "concurrently -k \"vite\" \"electron electron/main.cjs --dev\"",
    "electron:pack": "vite build && electron-builder --win"
  },
  "build": {
    "appId": "com.elvan.niril",
    "productName": "Elvan Niril",
    "npmRebuild": false,
    "directories": {
      "output": "node_modules/.dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@eslint/js": "^9.39.1",
    "@mui/icons-material": "^9.0.1",
    "@mui/material": "^9.0.1",
    "@mui/x-data-grid": "^9.3.0",
    "@mui/x-date-pickers": "^9.4.0",
    "@phosphor-icons/react": "^2.1.10",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^10.0.1",
    "cors": "^2.8.6",
    "dayjs": "^1.11.21",
    "dompurify": "^3.3.3",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "electron-packager": "^17.1.2",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "express": "^5.2.1",
    "framer-motion": "^12.40.0",
    "globals": "^16.5.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.577.0",
    "puppeteer": "^25.3.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.17.0",
    "react-zoom-pan-pinch": "^4.0.3",
    "ttf2woff2": "^8.0.1",
    "typescript": "^6.0.3",
    "vite": "^7.3.1",
    "vite-plugin-node-polyfills": "^0.28.0",
    "vite-plugin-pwa": "^1.2.0",
    "xlsx": "^0.18.5",
    "xlsx-js-style": "^1.2.0"
  }
}
